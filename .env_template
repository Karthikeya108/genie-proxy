# =============================================================================
# Genie Proxy - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Databricks Authentication ---
# Name of your Databricks CLI profile (run `databricks auth login` to create one)
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Alternatively, set these directly (used if no profile is set):
# DATABRICKS_HOST=https://adb-1234567890123456.7.azuredatabricks.net
# DATABRICKS_TOKEN=dapi...

# --- Lakebase (PostgreSQL) ---
# Name of the Lakebase database instance
PGAPPNAME=genie-proxy

# --- Genie Proxy Settings ---
# Databricks workspace URL for Genie API calls
# Falls back to DATABRICKS_HOST if not set
GENIE_PROXY_WORKSPACE_URL=

# Comma-separated Genie Space IDs to expose (leave empty to show all accessible spaces)
GENIE_PROXY_GENIE_SPACE_IDS=
